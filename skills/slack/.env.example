# Slack credentials for the slack skill
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
#
# Slack API calls require TWO values from your browser session:
#
# SLACK_USER_TOKEN: your session user token (starts with xoxc-)
#   Retrieve it by running this in the browser DevTools console
#   while on https://app.slack.com/client/<WORKSPACE_ID>:
#
#     JSON.parse(localStorage.localConfig_v2).teams[document.location.pathname.match(/^\/client\/([A-Z0-9]+)/)[1]].token
#
# SLACK_COOKIE: the value of the "d" session cookie (starts with xoxd-)
#   1. Open Slack in your browser: https://app.slack.com
#   2. Open DevTools (F12) → Application → Cookies → https://app.slack.com
#   3. Copy the value of the cookie named "d"
#
# Both values are required together for API authentication:
#   Authorization: Bearer <SLACK_USER_TOKEN>
#   Cookie: d=<SLACK_COOKIE>
#
# Note: these grant full access as your user. Keep them secret.

SLACK_USER_TOKEN=xoxc-your-token-here
SLACK_COOKIE=xoxd-your-cookie-here
