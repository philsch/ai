# Bitbucket Cloud credentials for the create-pull-request skill
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
#
# BITBUCKET_EMAIL: your Atlassian account email address
# BITBUCKET_API_TOKEN: an API token with the pullrequests:write scope
#   Create one at: https://id.atlassian.com/manage-profile/security/api-tokens

BITBUCKET_EMAIL=your-atlassian-account-email
BITBUCKET_API_TOKEN=your-api-token
